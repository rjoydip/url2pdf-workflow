{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "url2pdf",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-13",
  "observability": {
    "enabled": true,
  },
  "workflows": [
    {
      "name": "url2pdf-workflow",
      "binding": "WORKFLOW",
      "class_name": "Url2PdfWorkflow",
    },
  ],
  "browser": {
    "binding": "BROWSER",
    "remote": true,
  },
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "url2pdf-bucket",
    },
  ],
}
