{
  "name": "url2pdf-workflow",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bun tsc --noEmit",
    "lint": "oxlint . --format=github",
    "lint:fix": "oxlint . --fix && oxfmt .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "actions-up": "actions-up",
    "fallow": "fallow",
    "fallow:dead": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "fallow:fix": "fallow fix --dry-run",
    "fallow:health": "fallow health --format badge > .artifacts/fallow-health.svg"
  },
  "dependencies": {
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260628.1",
    "actions-up": "^1.14.3",
    "bun-types": "^1.3.14",
    "fallow": "^2.103.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.71.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.105.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint && bun run format:check && bun run typecheck"
  }
}
